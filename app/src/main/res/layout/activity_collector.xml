<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Back button -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_back"
        android:backgroundTint="@color/bg_card"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="8dp" />

    <!-- Total counter -->
    <TextView
        android:id="@+id/tvTotalPhotos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total: 0 foto"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp" />

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="280dp"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Photo preview after capture -->
    <ImageView
        android:id="@+id/imgPreview"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="8dp" />

    <!-- Selected class indicator -->
    <TextView
        android:id="@+id/tvSelectedClass"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/select_class"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:padding="8dp"
        android:background="@color/bg_card"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/previewView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Save confirmation -->
    <TextView
        android:id="@+id/tvSaveConfirm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/white"
        android:textSize="13sp"
        android:padding="8dp"
        android:background="@color/status_ready"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvSelectedClass"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Class grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvClasses"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvSaveConfirm"
        app:layout_constraintBottom_toBottomOf="@id/btnCapture"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="4dp" />

    <!-- Bottom buttons -->
    <Button
        android:id="@+id/btnCapture"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_capture"
        android:backgroundTint="@color/primary"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnImport"
        android:layout_margin="8dp" />

    <Button
        android:id="@+id/btnImport"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/btn_import"
        android:backgroundTint="@color/bg_card"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnCapture"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>