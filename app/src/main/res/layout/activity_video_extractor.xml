<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Compact header strip -->
    <LinearLayout
        android:id="@+id/headerStrip"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:padding="4dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/btn_back"
            android:backgroundTint="@color/bg_item"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/video_extractor_title"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvFrameCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/frame_count_default"
            android:textColor="@color/accent"
            android:textSize="12sp"
            android:paddingEnd="10dp" />
    </LinearLayout>

    <!-- Video info + Controls panel -->
    <LinearLayout
        android:id="@+id/layoutControls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="6dp"
        android:background="@color/bg_card"
        app:layout_constraintTop_toBottomOf="@id/headerStrip"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Kiri: pick + web -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="4dp">

            <Button
                android:id="@+id/btnPickVideo"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:text="@string/btn_pick_video"
                android:backgroundTint="@color/primary"
                android:textSize="10sp"
                android:layout_marginBottom="4dp" />

            <Button
                android:id="@+id/btnYoutube"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:text="@string/btn_search_web"
                android:backgroundTint="@color/youtube_red"
                android:textColor="@android:color/white"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Tengah: interval + video info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvVideoInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/video_info_default"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:gravity="center"
                android:layout_marginBottom="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_interval"
                android:textColor="@color/text_secondary"
                android:textSize="10sp" />

            <SeekBar
                android:id="@+id/seekInterval"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="10"
                android:progress="2"
                android:contentDescription="@string/seekbar_interval_desc" />

            <TextView
                android:id="@+id/tvInterval"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interval_default"
                android:textColor="@color/accent"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Kanan: extract -->
        <Button
            android:id="@+id/btnExtract"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/btn_extract"
            android:backgroundTint="@color/extract_green"
            android:textSize="11sp"
            android:layout_marginStart="4dp"
            android:enabled="false" />
    </LinearLayout>

    <!-- Progress -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        style="?android:attr/progressBarStyleHorizontal"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layoutControls"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Frame grid -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFrames"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/rv_frames_desc"
        app:layout_constraintTop_toBottomOf="@id/tvProgress"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:padding="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnSelectAll"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/btn_select_all"
            android:backgroundTint="@color/bg_item"
            android:textSize="11sp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnClearSelection"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/btn_cancel"
            android:backgroundTint="@color/bg_item"
            android:textSize="11sp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/btnAssignFrames"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="2"
            android:text="@string/btn_assign_class"
            android:backgroundTint="@color/primary"
            android:textSize="11sp"
            android:enabled="false" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>