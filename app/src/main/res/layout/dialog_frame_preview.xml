<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E6000000">

    <!-- Top bar: timestamp + blur badge + close -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#CC000000"
        android:padding="12dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvPreviewTimestamp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="00:00"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvPreviewBlur"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/preview_blur_badge"
            android:textColor="#FFFF00"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:background="#AA993300"
            android:visibility="gone"
            android:layout_marginEnd="12dp" />

        <Button
            android:id="@+id/btnClosePreview"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="@string/btn_close_preview"
            android:textSize="14sp"
            android:padding="0dp"
            android:backgroundTint="#555555" />

    </LinearLayout>

    <!-- Zoomable image (use PhotoView or fallback matrix ImageView) -->
    <ImageView
        android:id="@+id/imgPreviewFull"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="fitCenter"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Zoom hint -->
    <TextView
        android:id="@+id/tvZoomHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/preview_zoom_hint"
        android:textColor="#AAFFFFFF"
        android:textSize="11sp"
        android:background="#66000000"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="6dp" />

    <!-- Bottom bar: prev / select toggle / next / assign -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#CC000000"
        android:padding="10dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Prev frame -->
        <Button
            android:id="@+id/btnPrevFrame"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="@string/btn_prev_frame"
            android:textSize="13sp"
            android:padding="0dp"
            android:backgroundTint="#444444"
            android:layout_marginEnd="6dp" />

        <!-- Frame counter -->
        <TextView
            android:id="@+id/tvPreviewIndex"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="1 / 1"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:gravity="center" />

        <!-- Next frame -->
        <Button
            android:id="@+id/btnNextFrame"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="@string/btn_next_frame"
            android:textSize="13sp"
            android:padding="0dp"
            android:backgroundTint="#444444"
            android:layout_marginEnd="10dp" />

        <!-- Select / Deselect -->
        <Button
            android:id="@+id/btnToggleSelect"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="2"
            android:text="@string/btn_frame_select"
            android:textSize="12sp"
            android:backgroundTint="#1565C0"
            android:layout_marginEnd="6dp" />

        <!-- Assign langsung -->
        <Button
            android:id="@+id/btnAssignDirect"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="2"
            android:text="@string/btn_assign_direct"
            android:textSize="12sp"
            android:backgroundTint="#2E7D32" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>