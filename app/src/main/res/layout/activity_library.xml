<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Header strip -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_card"
        android:padding="4dp"
        android:gravity="center_vertical"
        xmlns:android="http://schemas.android.com/apk/res/android"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/btn_back"
            android:backgroundTint="@color/bg_item"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/tvCurrentClass"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Pilih class →"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:padding="6dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/tvPhotoCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 foto"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:paddingEnd="8dp" />

        <!-- Tombol manajemen kelas -->
        <Button
            android:id="@+id/btnManageClasses"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="⚙ Kelola"
            android:backgroundTint="#1565C0"
            android:textSize="11sp"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <!-- Class list (kiri, lebar tetap) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvClassList"
        android:layout_width="140dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:background="@color/bg_card" />

    <!-- Photo grid (kanan) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPhotos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/rvClassList"
        app:layout_constraintEnd_toEndOf="parent"
        android:padding="4dp" />

</androidx.constraintlayout.widget.ConstraintLayout>